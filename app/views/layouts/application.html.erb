<!DOCTYPE html>
<html>
  <head>
    <title>MCP Toggle</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <!-- This links to your main stylesheet (app/assets/stylesheets/application.css) -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="app-container">
      <!-- Rendering the DRY Sidebar Partial -->
      <% if logged_in? %>
        <%= render 'shared/sidebar' %>
      <% end %>

      <main class="main-content">
        <!-- Any flash messages for logins/errors -->
        <%= render 'shared/flash_messages' %> 
        
        <!-- This is where the specific page content loads -->
        <%= yield %> 
      </main>
    </div>
  </body>
</html>